# Step 1: Install & Import libraries
!pip install opencv-python-headless matplotlib numpy

import cv2
import numpy as np
import matplotlib.pyplot as plt
from google.colab import files
import random

print("="*50)
print("PROGRAM SEGMENTASI KOIN")
print("="*50)

# Step 2: Upload gambar dari komputer Anda
print("\n[1] SILAKAN UPLOAD GAMBAR KOIN ANDA")
print("Klik tombol 'Choose Files' lalu pilih gambar koin...")
print("Setelah upload selesai, tekan ENTER\n")

uploaded = files.upload()

# Ambil nama file yang diupload
for filename in uploaded.keys():
    print(f"File '{filename}' berhasil diupload!")
    gambar_path = filename
    break

# Step 3: Baca gambar
print(f"\n[2] Membaca gambar: {gambar_path}")
img_color = cv2.imread(gambar_path)
img_rgb = cv2.cvtColor(img_color, cv2.COLOR_BGR2RGB)
img_gray = cv2.cvtColor(img_color, cv2.COLOR_BGR2GRAY)

print(f"Ukuran gambar: {img_gray.shape}")

# Step 4: Thresholding (Otsu)
print("\n[3] Melakukan thresholding Otsu...")
_, thresh = cv2.threshold(img_gray, 0, 255, cv2.THRESH_BINARY_INV + cv2.THRESH_OTSU)

# Step 5: Operasi Morfologi (membersihkan noise)
print("[4] Membersihkan gambar dengan morfologi...")
kernel = np.ones((5,5), np.uint8)

# Closing = Dilasi lalu Erosi (tutup lubang)
closing = cv2.morphologyEx(thresh, cv2.MORPH_CLOSE, kernel)

# Opening = Erosi lalu Dilasi (hilangkan noise)
opening = cv2.morphologyEx(closing, cv2.MORPH_OPEN, kernel)

# Step 6: Deteksi kontur (cari batas-batas koin)
print("[5] Mendeteksi kontur koin...")
contours, _ = cv2.findContours(opening, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)

# Step 7: Filter koin berdasarkan ukuran (hapus noise kecil)
min_area = 500
koin_terdeteksi = []
for cnt in contours:
    area = cv2.contourArea(cnt)
    if area > min_area:
        koin_terdeteksi.append(cnt)

print(f"\n{'='*50}")
print(f"HASIL: Ditemukan {len(koin_terdeteksi)} buah koin")
print(f"{'='*50}")

# Step 8: Gambar hasil (bounding box dan nomor)
print("\n[6] Menggambar hasil deteksi...")
hasil = img_rgb.copy()
for i, cnt in enumerate(koin_terdeteksi):
    # Gambar bounding box
    x, y, w, h = cv2.boundingRect(cnt)
    cv2.rectangle(hasil, (x, y), (x+w, y+h), (0, 255, 0), 3)

    # Tulis nomor urut
    cv2.putText(hasil, str(i+1), (x, y-10),
                cv2.FONT_HERSHEY_SIMPLEX, 0.8, (255, 0, 0), 2)

    # Tambahkan lingkaran atau warna random untuk kontur
    color = (random.randint(0, 255), random.randint(0, 255), random.randint(0, 255))
    cv2.drawContours(hasil, [cnt], -1, color, 2)

# Step 9: Tampilkan semua hasil
print("[7] Menampilkan hasil...")

plt.figure(figsize=(15, 12))

# Gambar 1: Original
plt.subplot(2, 3, 1)
plt.imshow(img_rgb)
plt.title("1. Gambar Asli", fontsize=12)
plt.axis('off')

# Gambar 2: Grayscale
plt.subplot(2, 3, 2)
plt.imshow(img_gray, cmap='gray')
plt.title("2. Grayscale", fontsize=12)
plt.axis('off')

# Gambar 3: Threshold
plt.subplot(2, 3, 3)
plt.imshow(thresh, cmap='gray')
plt.title("3. Thresholding Otsu", fontsize=12)
plt.axis('off')

# Gambar 4: Setelah Morfologi
plt.subplot(2, 3, 4)
plt.imshow(opening, cmap='gray')
plt.title("4. Setelah Morfologi (Bersih)", fontsize=12)
plt.axis('off')

# Gambar 5: Kontur terdeteksi
kontur_display = np.zeros_like(img_gray)
cv2.drawContours(kontur_display, koin_terdeteksi, -1, 255, 2)
plt.subplot(2, 3, 5)
plt.imshow(kontur_display, cmap='gray')
plt.title(f"5. Kontur ({len(koin_terdeteksi)} koin)", fontsize=12)
plt.axis('off')

# Gambar 6: Hasil Akhir
plt.subplot(2, 3, 6)
plt.imshow(hasil)
plt.title(f"6. HASIL AKHIR: {len(koin_terdeteksi)} Koin", fontsize=12)
plt.axis('off')

plt.tight_layout()
plt.show()

print("\n" + "="*50)
print("PROGRAM SELESAI!")
print("="*50)
